# Copy to `.env` on the server (never commit the real .env):
#   cp .env.example .env  &&  edit TUNNEL_TOKEN
#
# Get the token from:
#   Cloudflare dashboard > Zero Trust > Networks > Tunnels
#   > (your tunnel) > Configure > copy the token from the install command
#   (the long string after `--token`).
TUNNEL_TOKEN=
